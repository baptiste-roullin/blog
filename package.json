{
  "name": "tout-ce-qui-bouge",
  "type": "module",
  "scripts": {
    "dev:webpack": "npx webpack --watch --mode development",
    "dev:bawesome": "node --env-file=.env node_modules/.bin/eleventy --quiet --config=.eleventy.ts --serve --incremental",
    "dev:postcss": "postcss src/assets/css/main.css -o www/assets/css/main.css --watch",
    "dev": "npm-run-all --parallel dev:* --print-label",
    "build:webpack": "npx webpack  --mode production",
    "build:bawesome": "node --env-file=.env node_modules/.bin/eleventy --config=.eleventy.ts",
    "build:postcss": "postcss --verbose src/assets/css/main.css -o www/assets/css/main.css",
    "build:search": "npx pagefind --site www ",
    "build": "run-s build:* --print-label"
  },
  "devDependencies": {
    "@11ty/eleventy": "^4.0.0-alpha.8",
    "@11ty/eleventy-fetch": "^5.1.0",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.4",
    "@11ty/eleventy-plugin-directory-output": "^1.0.1",
    "@11ty/eleventy-plugin-rss": "2.0.4",
    "@tailwindcss/forms": "*",
    "@tailwindcss/postcss": "^4.0.3",
    "@tailwindcss/typography": "*",
    "@types/luxon": "^3.1.0",
    "@types/markdown-it": "^14.1.1",
    "@types/markdown-it-container": "^2.0.5",
    "@types/node": "^25.0.2",
    "@types/nunjucks": "^3.2.1",
    "@types/webpack": "^5.28.0",
    "d3-color": "^3.1.0",
    "debug": "^4.3.4",
    "esm-seedrandom": "^3.0.5",
    "highlight.js": "^11.9.0",
    "linkedom": "^0.3.5",
    "lodash.clonedeep": "^4.5.0",
    "luxon": "^3.1.0",
    "markdown-it": "^14.0.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.1.4",
    "markdown-it-bracketed-spans": "^1.0.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-image-figures": "^2.1.0",
    "markdown-it-prism": "^3.0.1",
    "markdown-it-table-of-contents": "^1.1.0",
    "npm-run-all": "^4.1.5",
    "p-map": "^7.0.0",
    "pagefind": "^1.0.4",
    "postcss": "^8.5.0",
    "postcss-clean": "^1.2.2",
    "postcss-cli": "^11.0.0",
    "postcss-hash": "^3.0.0",
    "simple-nunjucks-loader": "github:baptiste-roullin/nunjucks-loader#dev",
    "skia-canvas": "^3.0.8",
    "tailwindcss": "^4.1.15",
    "webpack": "^5.102.0",
    "webpack-assets-manifest": "^6.2.0",
    "webpack-cli": "^6.0.1",
    "yaml": "^2.8.2",
    "zotero-api-client": "^0.46.0"
  },
  "dependencies": {
    "photoswipe": "^5.4.4",
    "text-metrics": "^4.0.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}